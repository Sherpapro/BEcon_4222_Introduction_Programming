    {
      "id": "iwfRwGzW8WMq6P4snMT5n",
      "type": "text",
      "x": 1928.390203164513,
      "y": -6969.382082750352,
      "width": 1373.9984755503392,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "FjVGH5TU_T7nP6XdDlAo9",
      "index": "bdj",
      "roundness": null,
      "seed": 1174118061,
      "version": 599,
      "versionNonce": 857407405,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773341168247,
      "link": null,
      "locked": false,
      "text": "After changing from maincode_v1_final_reviewed_r2.py to\nmaincode_v1_final_reviewd_r3, Juliet decided she'd had enough.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "After changing from maincode_v1_final_reviewed_r2.py to maincode_v1_final_reviewd_r3, Juliet decided she'd had enough.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "WSAsbx8FSUXB_MZ3y6Alv",
      "type": "text",
      "x": 1919.2179118055674,
      "y": -6113.069193222837,
      "width": 1422.3430582682295,
      "height": 271.28482393710874,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "FjVGH5TU_T7nP6XdDlAo9",
      "index": "bdk",
      "roundness": null,
      "seed": 718470275,
      "version": 1348,
      "versionNonce": 305826061,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773341195722,
      "link": null,
      "locked": false,
      "text": "In git, you can track each change in your code and who changed it. Each change is commented, in\na way which is easy to track down. \nIn git, you have versions of the project, not just versions of each file. A project involves\nmany scripts, which are interdependent.\nIn git, you can always go back to a previous working version.\nIn git, you can experiment on your own without breaking the main code (\"branching\")\n \n",
      "fontSize": 27.128482393710875,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In git, you can track each change in your code and who changed it. Each change is commented, in a way which is easy to track down. \nIn git, you have versions of the project, not just versions of each file. A project involves many scripts, which are interdependent.\nIn git, you can always go back to a previous working version.\nIn git, you can experiment on your own without breaking the main code (\"branching\")\n \n",
      "autoResize": false,
      "lineHeight": 1.25
    },
